---
interface Props {
  url: string;
  ogImage?: string;
  title?: string;
}

const { url, ogImage, title } = Astro.props;
const domain = new URL(url).hostname.replace('www.', '');
---

<a href={url} target="_blank" rel="noopener noreferrer" class="link-card">
  {ogImage && (
    <div class="link-card-img">
      <img src={ogImage} alt="" loading="lazy" referrerpolicy="no-referrer" />
    </div>
  )}
  <div class="link-card-body">
    <span class="link-card-title">{title || domain}</span>
    <span class="link-card-url">{domain}</span>
  </div>
</a>

<style>
  .link-card {
    display: flex;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    margin: 1.5rem 0;
    transition: border-color 0.15s;
  }

  .link-card:hover {
    border-color: rgba(255,255,255,0.2);
  }

  .link-card-img {
    width: 200px;
    flex-shrink: 0;
    overflow: hidden;
    background: #1a1a1a;
  }

  .link-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .link-card-body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0.8rem 1rem;
    min-width: 0;
  }

  .link-card-title {
    font-size: 0.85rem;
    font-weight: 500;
    color: #fff;
    line-height: 1.4;
    margin-bottom: 0.2rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .link-card-url {
    font-size: 0.72rem;
    color: var(--color-muted);
  }

  @media (max-width: 520px) {
    .link-card {
      flex-direction: column;
    }

    .link-card-img {
      width: 100%;
      aspect-ratio: 2 / 1;
    }
  }
</style>
