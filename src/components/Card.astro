---
interface Props {
  title: string;
  description?: string;
  href: string;
  date?: string;
  thumbnail?: string;
}

const { title, href, date, thumbnail } = Astro.props;
---

<a href={href} class="card">
  <div class="card-img">
    {thumbnail
      ? <Fragment>
          <img src={thumbnail} alt="" loading="lazy" class="bg" aria-hidden="true" />
          <img src={thumbnail} alt="" loading="lazy" class="fg" />
        </Fragment>
      : <div class="placeholder" />
    }
    <div class="card-info">
      <span class="card-title">{title}</span>
      {date && <time>{date}</time>}
    </div>
  </div>
</a>

<style>
  .card {
    display: block;
    overflow: hidden;
  }

  .card-img {
    position: relative;
    overflow: hidden;
    border-radius: 6px;
    aspect-ratio: 3 / 2;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.08);
  }

  .card-img .bg {
    position: absolute;
    inset: -30px;
    width: calc(100% + 60px);
    height: calc(100% + 60px);
    object-fit: cover;
    filter: blur(30px) saturate(0.8) brightness(0.55);
  }

  .card-img .fg {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.4s ease;
  }

  .card:hover .card-img .fg {
    transform: scale(1.02);
  }

  .placeholder {
    width: 100%;
    height: 100%;
    background: #1a1a1a;
  }

  .card-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.7rem 0.8rem;
    background: rgba(0,0,0,0.3);
    backdrop-filter: blur(6px);
    z-index: 1;
  }

  .card-title {
    display: block;
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.4;
    color: #fff;
  }

  time {
    display: block;
    font-size: 0.7rem;
    color: rgba(255,255,255,0.55);
    margin-top: 0.1rem;
  }
</style>
