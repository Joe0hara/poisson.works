---
interface Props {
  title: string;
  description?: string;
  href: string;
  date?: string;
  thumbnail?: string;
  themeColor?: string;
}

const { title, href, date, thumbnail, themeColor } = Astro.props;

// Build gradient from themeColor(s) or title hash
let gradientStyle: string;
if (themeColor) {
  const colors = themeColor.split(',').map(c => c.trim());
  if (colors.length === 1) {
    gradientStyle = `background: linear-gradient(in oklch 135deg, ${colors[0]} 0%, #0a0a0a 100%);`;
  } else {
    const stops = colors.map((c, i) => `${c} ${Math.round(i / (colors.length - 1) * 100)}%`).join(', ');
    gradientStyle = `background: linear-gradient(in oklch 135deg, ${stops});`;
  }
} else {
  let hash = 0;
  for (let i = 0; i < title.length; i++) {
    hash = title.charCodeAt(i) + ((hash << 5) - hash);
  }
  const hue = Math.abs(hash) % 360;
  gradientStyle = `background: linear-gradient(in oklch 135deg, oklch(35% 0.1 ${hue}) 0%, oklch(15% 0.03 ${(hue + 40) % 360}) 100%);`;
}
---

<a href={href} class="card">
  <div class="card-img">
    {thumbnail
      ? <Fragment>
          <img src={thumbnail} alt="" loading="lazy" class="bg" aria-hidden="true" />
          <img src={thumbnail} alt="" loading="lazy" class="fg" />
        </Fragment>
      : <div class="placeholder" style={gradientStyle}><div class="noise" /></div>
    }
    <div class="card-info">
      <span class="card-title">{title}</span>
      {date && <time>{date}</time>}
    </div>
  </div>
</a>

<style>
  .card {
    display: block;
    overflow: hidden;
  }

  .card-img {
    position: relative;
    overflow: hidden;
    border-radius: 6px;
    aspect-ratio: 3 / 2;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.08);
  }

  .card-img .bg {
    position: absolute;
    inset: -30px;
    width: calc(100% + 60px);
    height: calc(100% + 60px);
    object-fit: cover;
    filter: blur(30px) saturate(0.8) brightness(0.55);
  }

  .card-img .fg {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.4s ease;
  }

  .card:hover .card-img .fg {
    transform: scale(1.02);
  }

  .placeholder {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .noise {
    position: absolute;
    inset: 0;
    opacity: 0.35;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 128px 128px;
    mix-blend-mode: overlay;
  }

  .card-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.7rem 0.8rem;
    background: rgba(0,0,0,0.45);
    z-index: 1;
  }

  .card-title {
    display: block;
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.4;
    color: #fff;
  }

  time {
    display: block;
    font-size: 0.7rem;
    color: rgba(255,255,255,0.55);
    margin-top: 0.1rem;
  }
</style>
