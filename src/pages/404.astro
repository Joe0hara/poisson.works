---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found">
  <div class="not-found">
    <h1>404</h1>
    <p>Page not found</p>
    <a href="/">&larr; Home</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 8rem 0;
  }

  h1 {
    font-size: 4rem;
    font-weight: 700;
    color: var(--color-muted);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  p {
    color: var(--color-muted);
    margin-bottom: 2rem;
  }

  a {
    font-size: 0.85rem;
    color: var(--color-muted);
    transition: color 0.15s;
  }

  a:hover {
    color: #fff;
  }
</style>
